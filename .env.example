# ════════════════════════════════════════════════════
# Environment Variables – Arjens Lernplattform
# ════════════════════════════════════════════════════
# Kopiere diese Datei nach .env.local für lokale Entwicklung.
# Secrets NIEMALS ins Repository committen!
# ════════════════════════════════════════════════════

# ── App ───────────────────────────────────────────
NODE_ENV=development
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME="Arjens Lernplattform"

# ── (Optional) Analytics / Tracking ────────────────
# NEXT_PUBLIC_ANALYTICS_ID=

# ── (Optional) API Keys für spätere Features ──────
# DATABASE_URL=
# NEXTAUTH_SECRET=
# NEXTAUTH_URL=http://localhost:3000
